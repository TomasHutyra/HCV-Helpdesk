# Zkopírujte do .env a vyplňte hodnoty

DJANGO_SETTINGS_MODULE=helpdesk.settings.local
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Databáze (pro produkci PostgreSQL, lokálně SQLite — nevyplňujte DATABASE_URL)
# DATABASE_URL=postgres://user:password@localhost:5432/hcv_helpdesk

# E-mail — odchozí (SMTP)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.seznam.cz
EMAIL_PORT=587
EMAIL_HOST_USER=helpdesk@vase-firma.cz
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=helpdesk@vase-firma.cz
HELPDESK_EMAIL=helpdesk@vase-firma.cz

# E-mail — příchozí (IMAP)
IMAP_HOST=imap.seznam.cz
IMAP_PORT=993
IMAP_USER=helpdesk@vase-firma.cz
IMAP_PASSWORD=
IMAP_USE_SSL=True
IMAP_FOLDER=INBOX

# Celery / Redis (pro lokální vývoj není potřeba — tasky běží synchronně)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
